{
  "name": "e2e-playwright",
  "version": "1.0.0",
  "description": "Playwright E2E tests for learning.oreilly.review",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:prod": "PLAYWRIGHT_ENV=prod BASE_URL=https://learning.oreilly.com/ playwright test",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  },
  "dependencies": {
    "dayjs": "^1.9.6",
    "uuid": "^14.0.0"
  }
}
